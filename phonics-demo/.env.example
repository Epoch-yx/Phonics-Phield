# TTS 配置
# 可选值：webSpeech（默认，浏览器本地） | azure（Microsoft Azure 云 TTS）
VITE_TTS_PROVIDER=webSpeech

# Azure TTS 配置（仅当 VITE_TTS_PROVIDER=azure 时必填）
# 申请地址：https://azure.microsoft.com/products/ai-services/text-to-speech
VITE_AZURE_TTS_KEY=your-azure-tts-key-here
VITE_AZURE_TTS_REGION=eastasia
VITE_AZURE_TTS_VOICE=en-US-AriaNeural
